# Build environment
NODE_ENV=production

# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dorm-management?retryWrites=true&w=majority
DB_URI=mongodb+srv://username:password@cluster.mongodb.net/dorm-management?retryWrites=true&w=majority

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.vercel.app

# API Port (for local development)
PORT=5000

# Authentication (if needed)
JWT_SECRET=your_jwt_secret_key_here
